# Database connection URL (Supabase Postgres connection string)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/postgres

# Supabase Auth configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini AI Provider — used by the @helix/ai package for intent parsing, planning & explainability
# Model: gemini-2.5-flash-lite (fast, cost-efficient structured-output generation)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite
